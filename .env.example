# FinMind
FINMIND_TOKEN=

# LINE Notify ended service on 2025-03-31. Keep blank unless you have a
# compatible legacy/private endpoint setup.
LINE_NOTIFY_TOKEN=

# Email notification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Screening controls
MIN_VOLUME_SHARES=1000000
REQUEST_SLEEP_SEC=0.25
MAX_STOCKS=0
ENABLE_INTRADAY_CHECK=1
ENABLE_BIG_HOLDER_CHECK=1
INTRADAY_DAYS=18
STOP_LOSS_LOOKBACK_DAYS=20
STOP_LOSS_BUFFER_PCT=0.5
ATR_PERIOD=14
ATR_MULTIPLIER=1.5
YAHOO_BATCH_SIZE=80
